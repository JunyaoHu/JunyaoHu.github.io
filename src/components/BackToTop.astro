---
import { Icon } from 'astro-icon/components';
---

<button
	type="button"
	class="back-to-top"
	data-back-to-top
	aria-label="Back to top · 回到顶部"
>
	<Icon name="mdi:chevron-up" class="back-to-top__icon" aria-hidden="true" />
</button>

<script>
	document.querySelectorAll('[data-back-to-top]').forEach((btn) => {
		if (!(btn instanceof HTMLButtonElement)) return;
		const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

		const sync = () => {
			btn.classList.toggle('back-to-top--visible', window.scrollY > 280);
		};

		sync();
		window.addEventListener('scroll', sync, { passive: true });

		btn.addEventListener('click', () => {
			window.scrollTo({ top: 0, behavior: reduced ? 'auto' : 'smooth' });
			btn.blur();
		});
	});
</script>

<style>
	.back-to-top {
		appearance: none;
		-webkit-appearance: none;
		position: fixed;
		z-index: 90;
		right: max(1rem, env(safe-area-inset-right, 0px));
		bottom: max(1.25rem, env(safe-area-inset-bottom, 0px));
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.65rem;
		height: 2.65rem;
		padding: 0;
		margin: 0;
		font-family: inherit;
		border: 1px solid rgba(var(--gray), 0.14);
		border-radius: 999px;
		background: color-mix(in oklch, #fff 94%, rgb(var(--gray-light)) 6%);
		color: rgb(var(--gray-dark));
		box-shadow:
			0 1px 2px rgba(var(--black), 0.05),
			0 6px 20px rgba(var(--gray), 0.12);
		cursor: pointer;
		opacity: 0;
		visibility: hidden;
		pointer-events: none;
		transform: translateY(0.35rem);
		transition:
			opacity 0.22s ease,
			visibility 0.22s ease,
			transform 0.22s ease,
			border-color 0.18s ease,
			background 0.18s ease,
			color 0.18s ease,
			box-shadow 0.18s ease;
	}

	.back-to-top--visible {
		opacity: 1;
		visibility: visible;
		pointer-events: auto;
		transform: translateY(0);
	}

	.back-to-top:hover {
		border-color: color-mix(in oklch, var(--accent) 32%, rgb(var(--gray-light)) 68%);
		background: color-mix(in oklch, var(--accent) 10%, #fff 90%);
		color: color-mix(in oklch, var(--accent) 42%, rgb(var(--black)) 58%);
		box-shadow:
			0 2px 4px rgba(var(--black), 0.06),
			0 10px 28px rgba(var(--gray), 0.14);
	}

	.back-to-top:focus-visible {
		outline: 2px solid color-mix(in oklch, var(--accent) 45%, transparent);
		outline-offset: 3px;
	}

	.back-to-top__icon {
		width: 1.5rem;
		height: 1.5rem;
	}

	@media (prefers-reduced-motion: reduce) {
		.back-to-top {
			transition-duration: 0.01ms;
		}

		.back-to-top:not(.back-to-top--visible) {
			transform: none;
		}
	}
</style>
