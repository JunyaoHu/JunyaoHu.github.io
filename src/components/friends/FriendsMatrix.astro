---
import type { FriendLink } from '../../data/friends';

interface Props {
	friends: FriendLink[];
	categories: string[];
}

const { friends, categories } = Astro.props;

function cardTagsAttr(f: FriendLink) {
	return (f.tags ?? []).join('\n');
}
---

<div class="friends-matrix" data-friends-matrix>
	{
		categories.length > 0 && (
			<div class="friends-filter" role="tablist" aria-label="Filter by tag">
				<button
					type="button"
					class="friends-filter__btn friends-filter__btn--active"
					role="tab"
					aria-selected="true"
					data-friends-filter="all"
				>
					All
				</button>
				{categories.map((cat) => (
					<button
						type="button"
						class="friends-filter__btn"
						role="tab"
						aria-selected="false"
						data-friends-filter={cat}
					>
						{cat.replace(/^@/, '')}
					</button>
				))}
			</div>
		)
	}

	<ul class="friends-grid">
		{
			friends.map((f) => (
				<li class="friends-grid__item" data-friends-card>
					<a
						class="friends-card"
						href={f.siteurl}
						target="_blank"
						rel="noopener noreferrer"
						data-tags={cardTagsAttr(f)}
					>
						<img
							class="friends-card__avatar"
							src={f.imgurl}
							alt=""
							width="72"
							height="72"
							loading="lazy"
							decoding="async"
							referrerpolicy="no-referrer"
						/>
						<div class="friends-card__body">
							<div class="friends-card__title">{f.title}</div>
							<p class="friends-card__desc">{f.desc}</p>
							{
								f.tags && f.tags.length > 0 && (
									<div class="friends-card__tags">
										{f.tags.map((t) => (
											<span class="friends-card__tag">{t.replace(/^@/, '')}</span>
										))}
									</div>
								)
							}
						</div>
					</a>
				</li>
			))
		}
	</ul>
</div>

<script is:inline>
	(function () {
		document.querySelectorAll('[data-friends-matrix]').forEach(function (root) {
			var filterRoot = root.querySelector('.friends-filter');
			if (!filterRoot) return;
			var buttons = filterRoot.querySelectorAll('[data-friends-filter]');
			var cards = root.querySelectorAll('[data-friends-card]');

			function setActive(activeBtn) {
				buttons.forEach(function (b) {
					b.classList.toggle('friends-filter__btn--active', b === activeBtn);
					b.setAttribute('aria-selected', b === activeBtn ? 'true' : 'false');
				});
			}

			function applyFilter(cat) {
				cards.forEach(function (li) {
					var a = li.querySelector('a[data-tags]');
					var raw = a ? a.getAttribute('data-tags') || '' : '';
					var tags = raw ? raw.split('\n').filter(Boolean) : [];
					var show = cat === 'all' || tags.indexOf(cat) !== -1;
					if (show) li.removeAttribute('hidden');
					else li.setAttribute('hidden', '');
				});
			}

			buttons.forEach(function (btn) {
				btn.addEventListener('click', function () {
					var cat = btn.getAttribute('data-friends-filter') || 'all';
					setActive(btn);
					applyFilter(cat);
				});
			});
		});
	})();
</script>

<style>
	.friends-matrix {
		margin-bottom: 0;
	}

	.friends-filter {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.4rem 0.5rem;
		margin-bottom: 1.25rem;
	}

	.friends-filter__btn {
		cursor: pointer;
		border: 1px solid rgba(var(--gray), 0.14);
		padding: 0.32em 0.78em;
		font-size: 0.75rem;
		font-weight: 500;
		font-family: inherit;
		letter-spacing: 0.02em;
		border-radius: 999px;
		background: transparent;
		color: rgb(var(--gray-dark));
		transition:
			background 0.16s ease,
			color 0.16s ease,
			border-color 0.16s ease;
	}

	.friends-filter__btn:hover {
		border-color: rgba(var(--gray), 0.22);
		background: color-mix(in oklch, rgb(var(--gray-light)) 96%, var(--accent) 4%);
		color: rgb(var(--black));
	}

	.friends-filter__btn--active {
		background: color-mix(in oklch, var(--accent) 13%, #fff 87%);
		border-color: color-mix(in oklch, var(--accent) 32%, rgb(var(--gray-light)) 68%);
		color: color-mix(in oklch, var(--accent) 42%, rgb(var(--black)) 58%);
		font-weight: 600;
	}

	.friends-filter__btn--active:hover {
		background: color-mix(in oklch, var(--accent) 18%, #fff 82%);
		border-color: color-mix(in oklch, var(--accent) 38%, rgb(var(--gray)) 62%);
		color: color-mix(in oklch, var(--accent) 48%, rgb(var(--black)) 52%);
	}

	.friends-grid {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(min(100%, 288px), 1fr));
		gap: 0.85rem;
	}

	.friends-grid__item[hidden] {
		display: none;
	}

	.friends-card {
		--fc-bg: color-mix(in oklch, #fff 96%, rgb(var(--gray-light)) 4%);
		--fc-edge: rgba(var(--gray), 0.09);
		display: flex;
		align-items: flex-start;
		gap: 0.8rem;
		height: 100%;
		box-sizing: border-box;
		padding: 1rem 1.1rem;
		border-radius: 12px;
		border: 1px solid var(--fc-edge);
		background: var(--fc-bg);
		text-decoration: none;
		color: inherit;
		box-shadow:
			0 1px 0 rgba(var(--black), 0.03),
			0 8px 22px rgba(var(--gray), 0.05);
		transition:
			border-color 0.2s ease,
			box-shadow 0.2s ease;
	}

	.friends-card:hover {
		border-color: color-mix(in oklch, var(--accent) 18%, rgba(var(--gray), 0.12) 82%);
		box-shadow:
			0 2px 4px rgba(var(--black), 0.06),
			0 8px 20px rgba(var(--gray), 0.13),
			0 20px 48px rgba(var(--gray), 0.1);
	}

	.friends-card__avatar {
		flex-shrink: 0;
		width: 3.75rem;
		height: 3.75rem;
		border-radius: 10px;
		object-fit: cover;
		border: 1px solid rgba(var(--gray), 0.1);
		background: rgb(var(--gray-light));
		box-shadow: 0 1px 2px rgba(var(--black), 0.04);
	}

	.friends-card__body {
		min-width: 0;
		flex: 1;
		display: flex;
		flex-direction: column;
		gap: 0.22rem;
	}

	.friends-card__title {
		font-size: 1rem;
		font-weight: 700;
		line-height: 1.28;
		letter-spacing: -0.015em;
		color: rgb(var(--black));
		transition: color 0.15s ease;
	}

	.friends-card:hover .friends-card__title {
		color: color-mix(in oklch, var(--accent) 35%, rgb(var(--black)) 65%);
	}

	.friends-card__desc {
		margin: 0;
		font-size: 0.8125rem;
		line-height: 1.5;
		color: rgb(var(--gray));
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.friends-card__tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.3rem;
		margin-top: 0.4rem;
	}

	.friends-card__tag {
		font-size: 0.625rem;
		font-weight: 600;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		padding: 0.22em 0.5em;
		border-radius: 6px;
		background: color-mix(in oklch, rgb(var(--gray-light)) 94%, var(--accent) 6%);
		color: rgb(var(--gray));
		border: 1px solid rgba(var(--gray), 0.08);
	}
</style>
