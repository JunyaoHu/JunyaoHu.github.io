---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import type { ImageMetadata } from 'astro';
import type { SocialLink } from '../../data/homepage';

interface Props {
	name: string;
	nameZh?: string;
	tagline?: string;
	avatar: ImageMetadata;
	alt?: string;
	socialLinks?: SocialLink[];
	updated?: string;
}

const { name, nameZh, tagline, avatar, alt = '', socialLinks, updated } = Astro.props;

function socialHref(url: string) {
	if (/^https?:\/\//i.test(url) || url.startsWith('mailto:')) return url;
	return url.startsWith('/') ? url : `/${url}`;
}

function openInNewTab(url: string) {
	return url.startsWith('http');
}

function socialTargetBlank(s: SocialLink) {
	return openInNewTab(s.url) || s.openInNewTab === true;
}
---

<section class="home-hero" aria-label="Profile">
	<div class="home-hero__visual">
		<Image class="home-hero__avatar" src={avatar} alt={alt || name} width={160} height={160} />
	</div>
	<div class="home-hero__text">
		<h1 class="home-hero__name">
			{name}
			{nameZh && <span class="home-hero__name-zh">{nameZh}</span>}
		</h1>
		{tagline && <p class="home-hero__tagline">{tagline}</p>}
		{
			socialLinks && socialLinks.length > 0 && (
				<div class="home-hero__social" role="list">
					{socialLinks.map((s) => (
						<a
							role="listitem"
							class="home-hero__social-link"
							href={socialHref(s.url)}
							target={socialTargetBlank(s) ? '_blank' : undefined}
							rel={socialTargetBlank(s) ? 'noopener noreferrer' : undefined}
							aria-label={s.name}
						>
							<span class="sr-only">{s.name}</span>
							<Icon name={s.icon} class="home-hero__social-icon" aria-hidden="true" />
						</a>
					))}
				</div>
			)
		}
	</div>
	{updated && <p class="home-hero__updated">{updated}</p>}
</section>

<style>
	.home-hero__social {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.45rem;
		margin-top: 0.65rem;
		padding: 0;
		list-style: none;
	}

	.home-hero__social-link {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2.35rem;
		height: 2.35rem;
		border-radius: 0.45rem;
		background: rgb(var(--gray-light));
		color: rgb(var(--gray-dark));
		text-decoration: none;
		transition:
			background-color 0.15s ease,
			color 0.15s ease,
			transform 0.15s ease;
	}

	.home-hero__social-link:hover {
		background: rgba(var(--gray), 0.14);
		color: var(--accent);
		transform: translateY(-1px);
	}

	.home-hero__social-icon {
		width: 1.5rem;
		height: 1.5rem;
	}

	.home-hero__social-icon :global(svg) {
		display: block;
		width: 100%;
		height: 100%;
	}

	.home-hero__updated {
		width: 100%;
		margin: 0.25rem 0 0;
		padding-top: 0.4rem;
		font-size: 0.72rem;
		color: rgb(var(--gray));
		line-height: 1.4;
		text-align: right;
		opacity: 0.75;
	}
</style>
