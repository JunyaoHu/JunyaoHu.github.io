---
import HeaderLeft from './header/HeaderLeft.astro';
import HeaderRight from './header/HeaderRight.astro';
---

<header>
	<nav>
		<HeaderLeft />
		<HeaderRight />
	</nav>
</header>

<style>
	/* ── 背景壳 ── */
	header {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 100;
		box-sizing: border-box;
		height: var(--site-header-height);
		margin: 0;
		padding: 0 1em;
		display: flex;
		align-items: center;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
	}

	/* ── 内部布局 ── */
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		width: 100%;
		height: var(--site-header-height);
		box-sizing: border-box;
	}
</style>
