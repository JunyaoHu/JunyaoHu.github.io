---
import { getCollection, render } from 'astro:content';
import MarkdownPage from '../../layouts/MarkdownPage.astro';

const entries = await getCollection('manual');
const entry = entries[0];
if (!entry) {
	throw new Error('Missing src/content/manual.md');
}
const { Content } = await render(entry);
---

<MarkdownPage title="个人手册" description="基础信息与说明">
	<Content />
</MarkdownPage>
