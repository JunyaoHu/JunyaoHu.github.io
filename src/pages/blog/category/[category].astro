---
import { getCollection } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import BlogCard from '../../../components/BlogCard.astro';
import Footer from '../../../components/Footer.astro';
import Header from '../../../components/Header.astro';

export async function getStaticPaths() {
	const allPosts = await getCollection('blog');
	const categories = [...new Set(
		allPosts
			.map((p) => p.data.category?.trim())
			.filter((c): c is string => Boolean(c)),
	)];
	return categories.map((category) => ({
		params: { category },
		props: {
			category,
			posts: allPosts
				.filter((p) => p.data.category?.trim() === category)
				.sort((a, b) => b.data.publishedDate.valueOf() - a.data.publishedDate.valueOf()),
		},
	}));
}

interface Props {
	category: string;
	posts: Awaited<ReturnType<typeof getCollection<'blog'>>>;
}

const { category, posts } = Astro.props;
---

<!doctype html>
<html lang="zh-Hans">
	<head>
		<BaseHead title={`分类：${category}`} description={`分类「${category}」下的所有文章，共 ${posts.length} 篇。`} />
		<style>
			main.blog-index {
				width: min(840px, calc(100% - 2rem));
				max-width: 100%;
				margin: 0 auto;
				padding: 1.5rem 1rem 3.25rem;
				box-sizing: border-box;
			}
			.blog-index__header {
				margin: 0 0 1.5rem;
				padding-bottom: 0.85rem;
				border-bottom: 1px solid rgba(var(--gray), 0.12);
			}
			.blog-index__back {
				display: inline-flex;
				align-items: center;
				gap: 0.3rem;
				font-size: 0.78rem;
				font-weight: 500;
				line-height: 1;
				color: rgb(var(--gray));
				text-decoration: none;
				margin-bottom: 0.65rem;
				transition: color 0.15s ease;
			}
			.blog-index__back:hover {
				color: var(--accent);
			}
			.blog-index__title-row {
				display: flex;
				align-items: baseline;
				gap: 0.75rem;
				flex-wrap: wrap;
			}
			.blog-index__heading {
				margin: 0;
				font-size: 1.5rem;
				font-weight: 600;
				letter-spacing: -0.03em;
				color: rgb(var(--black));
			}
			.blog-index__badge {
				display: inline-flex;
				align-items: center;
				padding: 0.2em 0.65em 0.22em;
				font-size: 0.78rem;
				font-weight: 600;
				letter-spacing: 0.02em;
				color: color-mix(in oklch, var(--accent) 82%, rgb(var(--gray-dark)) 18%);
				background: color-mix(in oklch, var(--accent) 10%, transparent 90%);
				border: 1px solid color-mix(in oklch, var(--accent) 22%, transparent 78%);
				border-radius: 6px;
			}
			.blog-index__count {
				font-size: 0.84rem;
				color: rgb(var(--gray));
				font-weight: 400;
			}
			.blog-index__list {
				list-style: none;
				margin: 0;
				padding: 0;
				display: flex;
				flex-direction: column;
				gap: 1rem;
			}
			@media (prefers-reduced-motion: reduce) {
				.blog-index__back {
					transition: none;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main class="blog-index">
			<div class="blog-index__header">
				<a class="blog-index__back" href="/blog/">
					<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6" /></svg>
					Go Back to Blog List
				</a>
				<div class="blog-index__title-row">
					<h1 class="blog-index__heading">
						<span class="blog-index__badge">{category}</span>
					</h1>
					<span class="blog-index__count">{posts.length} articles</span>
				</div>
			</div>
			<ul class="blog-index__list">
				{posts.map((post) => <BlogCard post={post} />)}
			</ul>
		</main>
		<Footer />
	</body>
</html>
