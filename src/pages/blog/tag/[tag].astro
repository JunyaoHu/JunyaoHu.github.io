---
import { getCollection } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import BlogCard from '../../../components/BlogCard.astro';
import Footer from '../../../components/Footer.astro';
import Header from '../../../components/Header.astro';
import { siteVisibility } from '../../../data/siteVisibility';

export async function getStaticPaths() {
	if (!siteVisibility.blog) return [];
	const allPosts = await getCollection('blog');
	const tagMap = new Map<string, Awaited<ReturnType<typeof getCollection<'blog'>>>>();

	for (const post of allPosts) {
		for (const rawTag of post.data.tags ?? []) {
			const tag = rawTag.trim().startsWith('#') ? rawTag.trim().slice(1) : rawTag.trim();
			if (!tag) continue;
			if (!tagMap.has(tag)) tagMap.set(tag, []);
			tagMap.get(tag)!.push(post);
		}
	}

	return [...tagMap.entries()].map(([tag, posts]) => ({
		params: { tag },
		props: {
			tag,
			posts: posts.sort(
				(a, b) => b.data.publishedDate.valueOf() - a.data.publishedDate.valueOf(),
			),
		},
	}));
}

interface Props {
	tag: string;
	posts: Awaited<ReturnType<typeof getCollection<'blog'>>>;
}

const { tag, posts } = Astro.props;
if (!siteVisibility.blog) {
	return Astro.redirect('/404');
}
---

<!doctype html>
<html lang="zh-Hans">
	<head>
		<BaseHead title={`标签：#${tag}`} description={`标签「#${tag}」下的所有文章，共 ${posts.length} 篇。`} />
		<style>
			main.blog-index {
				width: min(840px, calc(100% - 2rem));
				max-width: 100%;
				margin: 0 auto;
				padding: 1.5rem 1rem 3.25rem;
				box-sizing: border-box;
			}
			.blog-index__header {
				margin: 0 0 1.5rem;
				padding-bottom: 0.85rem;
				border-bottom: 1px solid rgba(var(--gray), 0.12);
			}
			.blog-index__back {
				display: inline-flex;
				align-items: center;
				gap: 0.3rem;
				font-size: 0.78rem;
				font-weight: 500;
				color: rgb(var(--gray));
				text-decoration: none;
				margin-bottom: 0.65rem;
				transition: color 0.15s ease;
			}
			.blog-index__back:hover {
				color: var(--accent);
			}
			.blog-index__title-row {
				display: flex;
				align-items: baseline;
				gap: 0.75rem;
				flex-wrap: wrap;
			}
			.blog-index__heading {
				margin: 0;
				font-size: 1.5rem;
				font-weight: 600;
				letter-spacing: -0.03em;
				color: rgb(var(--black));
			}
			.blog-index__tag-badge {
				display: inline-flex;
				align-items: center;
				padding: 0.5em 0.72em 0.4em;
				font-size: 0.88rem;
				font-weight: 600;
				line-height: 1.2;
				letter-spacing: 0.03em;
				text-transform: uppercase;
				border-radius: 8px;
				border: 1px solid rgba(var(--gray), 0.2);
				background: rgba(255, 255, 255, 0.6);
				color: color-mix(in oklch, rgb(var(--gray-dark)) 72%, rgb(var(--gray)) 28%);
			}
			.blog-index__count {
				font-size: 0.84rem;
				color: rgb(var(--gray));
				font-weight: 400;
			}
			.blog-index__list {
				list-style: none;
				margin: 0;
				padding: 0;
				display: flex;
				flex-direction: column;
				gap: 1rem;
			}
			@media (prefers-reduced-motion: reduce) {
				.blog-index__back {
					transition: none;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main class="blog-index">
			<div class="blog-index__header">
				<a class="blog-index__back" href="/blog/">
					<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6" /></svg>
					Go Back to Blog List
				</a>
				<div class="blog-index__title-row">
					<h1 class="blog-index__heading">
						<span class="blog-index__tag-badge">#{tag}</span>
					</h1>
					<span class="blog-index__count">{posts.length} articles</span>
				</div>
			</div>
			<ul class="blog-index__list">
				{posts.map((post) => <BlogCard post={post} />)}
			</ul>
		</main>
		<Footer />
	</body>
</html>
