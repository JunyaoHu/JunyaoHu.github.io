---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import BlogCard from '../../components/BlogCard.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.publishedDate.valueOf() - a.data.publishedDate.valueOf(),
);
---

<!doctype html>
<html lang="zh-Hans">
	<head>
		<BaseHead title="Blog" description={SITE_DESCRIPTION} />
		<style>
			main.blog-index {
				width: min(840px, calc(100% - 2rem));
				max-width: 100%;
				margin: 0 auto;
				padding: 1.5rem 1rem 3.25rem;
				box-sizing: border-box;
			}
			.blog-index__heading {
				margin: 0 0 1.5rem;
				padding-bottom: 0.85rem;
				font-size: 1.5rem;
				font-weight: 600;
				letter-spacing: -0.03em;
				color: rgb(var(--black));
				border-bottom: 1px solid rgba(var(--gray), 0.12);
			}
			.blog-index__list {
				list-style: none;
				margin: 0;
				padding: 0;
				display: flex;
				flex-direction: column;
				gap: 1rem;
			}
		</style>
	</head>
	<body>
		<Header />
		<main class="blog-index">
			<h1 class="blog-index__heading">Blog</h1>
			<ul class="blog-index__list">
				{posts.map((post) => <BlogCard post={post} />)}
			</ul>
		</main>
		<Footer />
	</body>
</html>
