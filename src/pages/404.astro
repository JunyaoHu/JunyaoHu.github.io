---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="zh-Hans">
	<head>
		<BaseHead title="404 Not Found" description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="not-found-page">
			<section class="not-found-card">
				<p class="not-found-card__code">404</p>
				<h1 class="not-found-card__title">Oops, this page is not found.</h1>
				<p class="not-found-card__desc">
					You can explore other pages while you are here.
				</p>
				<a class="not-found-card__btn" href="/">Take me home</a>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	main.not-found-page {
		min-height: calc(100vh - var(--site-header-height));
		display: grid;
		place-items: center;
		padding: 2rem 1rem 4rem;
		box-sizing: border-box;
	}

	.not-found-card {
		width: min(92%, 560px);
		padding: 2.25rem 1.5rem 2rem;
		border-radius: 14px;
		border: 1px solid rgba(var(--gray), 0.14);
		background: rgba(255, 255, 255, 0.72);
		text-align: center;
		box-shadow: 0 8px 28px rgba(var(--gray), 0.08);
	}

	.not-found-card__code {
		margin: 0;
		font-size: clamp(2.6rem, 8vw, 4rem);
		line-height: 1;
		font-weight: 700;
		letter-spacing: -0.04em;
		color: color-mix(in oklch, var(--accent) 72%, rgb(var(--black)) 28%);
	}

	.not-found-card__title {
		margin: 0.55rem 0 0.65rem;
		font-size: clamp(1.25rem, 3.7vw, 1.65rem);
		line-height: 1.3;
		color: rgb(var(--black));
	}

	.not-found-card__desc {
		margin: 0 auto 1.35rem;
		max-width: 32em;
		font-size: 0.95rem;
		line-height: 1.65;
		color: rgb(var(--gray));
	}

	.not-found-card__btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.58em 1.05em 0.52em;
		border-radius: 9px;
		border: 1px solid color-mix(in oklch, var(--accent) 30%, rgba(var(--gray), 0.2) 70%);
		background: color-mix(in oklch, var(--accent) 12%, #fff 88%);
		color: color-mix(in oklch, var(--accent) 62%, rgb(var(--black)) 38%);
		font-size: 0.9rem;
		font-weight: 600;
		text-decoration: none;
		transition: background 0.15s ease, border-color 0.15s ease, transform 0.15s ease;
	}

	.not-found-card__btn:hover {
		background: color-mix(in oklch, var(--accent) 18%, #fff 82%);
		border-color: color-mix(in oklch, var(--accent) 42%, rgba(var(--gray), 0.2) 58%);
		transform: translateY(-1px);
	}

	@media (prefers-reduced-motion: reduce) {
		.not-found-card__btn {
			transition: none;
		}
	}
</style>

